# APEX TERMINAL Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# 
# IMPORTANT: Never commit .env files to version control!
# ============================================================

# ------------------------------------------------------------
# Required: Supabase Configuration
# ------------------------------------------------------------
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ------------------------------------------------------------
# Required: API Proxy URL (for secure API calls)
# ------------------------------------------------------------
# In production: Set to your Vercel/Cloudflare deployment URL
# In development: Leave empty to use relative paths (requires local proxy)
VITE_API_PROXY_URL=

# ------------------------------------------------------------
# Optional: App Configuration
# ------------------------------------------------------------
VITE_APP_NAME=APEX TERMINAL
VITE_APP_VERSION=2.0.0
VITE_DEBUG=false

# ------------------------------------------------------------
# Optional: Feature Flags
# ------------------------------------------------------------
VITE_ENABLE_AI=true
VITE_ENABLE_PRO=false

# ============================================================
# SERVER-SIDE CONFIGURATION (For Vercel/Cloudflare deployment)
# ============================================================
# These should be set in your hosting platform's environment variables
# NOT in .env files (they use VITE_ prefix which exposes them to client!)

# ------------------------------------------------------------
# AI APIs
# ------------------------------------------------------------
# Google Gemini (FREE: 1,500 req/day)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (paid)
OPENAI_API_KEY=

# Anthropic (paid)
ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# Crypto Data APIs
# ------------------------------------------------------------
# CoinGecko Pro (optional: higher rate limits)
COINGECKO_API_KEY=

# CryptoCompare (FREE: 100k calls/month)
CRYPTOCOMPARE_API_KEY=

# Twelve Data (FREE: 800 calls/day)
TWELVEDATA_API_KEY=

# ------------------------------------------------------------
# News APIs
# ------------------------------------------------------------
# GNews (FREE: 100 req/day)
GNEWS_API_KEY=

# NewsAPI (FREE: 100 req/day)
NEWSAPI_KEY=

# ------------------------------------------------------------
# Blockchain APIs
# ------------------------------------------------------------
# Etherscan (FREE: 5 calls/sec)
ETHERSCAN_API_KEY=

# ------------------------------------------------------------
# Economic Data APIs
# ------------------------------------------------------------
# FRED (FREE with key for higher rate limits)
FRED_API_KEY=
