# Twelve Data (FREE: 800 calls/day)
# Get key: https://twelvedata.com/
VITE_TWELVEDATA_API_KEY=

# ------------------------------------------------------------
# News APIs (optional — app uses fallback RSS feeds)
# ------------------------------------------------------------

# GNews (FREE: 100 req/day)
# Get key: https://gnews.io/
